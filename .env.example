# =============================================================================
# grounded-ops-agent  --  example environment file
# Copy to .env and fill in. The app validates this at startup and fails fast
# with a clear message if anything required is missing or inconsistent.
# NEVER commit a real .env. Only .env.example is tracked.
# =============================================================================

# --- Database -----------------------------------------------------------------
# Postgres + pgvector. Matches docker-compose.yml defaults.
DATABASE_URL=postgresql+asyncpg://ops:ops@localhost:5432/ops
# asyncpg connection pool size (tune for your hardware).
DB_POOL_SIZE=10

# --- Embeddings ---------------------------------------------------------------
# Provider: "huggingface" (local sentence-transformers, no API key, default)
#           or "openai" (requires OPENAI_API_KEY).
EMBEDDING_PROVIDER=huggingface
# Model id. Its vector dimension is stamped into the index + migration.
#   huggingface: BAAI/bge-small-en-v1.5 (384d, default) | all-MiniLM-L6-v2 (384d)
#   openai:      text-embedding-3-small (1536d)
# Switching providers/models requires re-embedding + rebuilding both indexes.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- LLM provider -------------------------------------------------------------
# Provider: "anthropic" (default) or "openai". At least one provider key below
# is required. The OpenAI embedding option additionally requires OPENAI_API_KEY.
LLM_PROVIDER=anthropic
# Model id (kept out of code; do not hardcode model strings in code paths).
#   anthropic: claude-opus-4-7 (default) | claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
#   openai:    gpt-4o | gpt-4o-mini
LLM_MODEL=claude-opus-4-7

# Provider API keys (only the one(s) you use are required).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Retrieval ----------------------------------------------------------------
# Cross-encoder reranker (BAAI/bge-reranker-base). Off by default: slow on CPU.
RERANKER_ENABLED=false
# Reciprocal Rank Fusion constant.
RRF_K=60
# Default number of chunks returned by retrieval.
RETRIEVAL_TOP_K=8

# --- MCP analytics server -----------------------------------------------------
# Transport between orchestrator and the analytics server:
#   "stdio" (default; orchestrator spawns the server as a subprocess)
#   "streamable-http" (networked / deployed setup)
MCP_TRANSPORT=stdio
# Only used when MCP_TRANSPORT=streamable-http.
MCP_SERVER_URL=http://127.0.0.1:8848/mcp
# Hard cap on rows any analytics tool may return.
MCP_MAX_RESULT_ROWS=1000

# --- Agent guardrails ---------------------------------------------------------
MAX_AGENT_STEPS=6
PER_REQUEST_TOKEN_BUDGET=30000
TOOL_TIMEOUT_SECONDS=15
MAX_TOOL_RETRIES=2
# Reserve this many tokens of headroom for the model's output per step.
MAX_OUTPUT_TOKENS=2000
# Enable Anthropic adaptive thinking (off by default for predictable token
# budgeting and a simpler agent loop). Has no effect on OpenAI.
LLM_THINKING=false

# --- Evaluation ---------------------------------------------------------------
# Judge model for the faithfulness LLM-as-judge. Pinned + recorded in reports.
EVAL_JUDGE_MODEL=claude-opus-4-7
# Seed for the synthetic data generator (reproducible eval).
DATA_SEED=1337

# --- Server / app -------------------------------------------------------------
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
# Max characters accepted for a user query / ingested document (input limits).
MAX_QUERY_CHARS=4000
MAX_DOCUMENT_CHARS=200000
